<?xml version="1.0" encoding="UTF-8"?>
<configuration>

  <!-- Serve /media/* as static files (bypass httpPlatformHandler) -->
  <location path="media">
    <system.webServer>
      <handlers>
        <clear />
        <add name="StaticFile"
             path="*"
             verb="GET,HEAD"
             modules="StaticFileModule"
             resourceType="File"
             requireAccess="Read" />
      </handlers>
    </system.webServer>
  </location>


  <!-- Everything else goes to Uvicorn/Django -->
  <system.webServer>
    <handlers>
      <add name="httpPlatformHandler"
           path="*"
           verb="*"
           modules="httpPlatformHandler"
           resourceType="Unspecified"
           requireAccess="Script" />
    </handlers>

    <httpPlatform stdoutLogEnabled="true"
                  stdoutLogFile=".\logs\python.log"
                  startupTimeLimit="20"
                  processPath="C:\inetpub\wwroot\cusas_app\.venv\Scripts\python.exe"
                  arguments="-m uvicorn configuration.asgi:application --port %HTTP_PLATFORM_PORT%">
      <environmentVariables>
        <environmentVariable name="PYTHONUNBUFFERED" value="1" />
        <environmentVariable name="DJANGO_SETTINGS_MODULE" value="configuration.settings" />
      </environmentVariables>
    </httpPlatform>

    <httpErrors existingResponse="PassThrough" />
  </system.webServer>

</configuration>
